{
  "name": "yearbeat",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "db:push": "pnpm --filter @yearbeat/backend prisma db push",
    "db:generate": "pnpm --filter @yearbeat/backend prisma generate"
  },
  "devDependencies": {
    "turbo": "^2.1.1"
  }
}
